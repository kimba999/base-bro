# Public site URL (no trailing slash) — used in manifest + OG
NEXT_PUBLIC_SITE_URL=https://base-bro.vercel.app

# Farcaster domain manifest signing (never commit real values)
# Export from Warpcast → Settings → Developer → Domains / Signer
FARCASTER_CUSTODY_PRIVATE_KEY=
FARCASTER_DOMAIN=base-bro.vercel.app
# Optional — auto-detected from custody address on Optimism IdRegistry
FARCASTER_FID=

# Hardhat / BaseScan (optional)
BASESCAN_API_KEY=
BASE_RPC_URL=https://mainnet.base.org
